# Diabetes MVP - Environment Configuration
# Copy this file to .env and adjust values

# Database
DIABETES_MVP_DATABASE_URL=sqlite:///./diabetes_mvp.db

# Security
DIABETES_MVP_SECRET_KEY=mvp-dev-secret-key-change-in-production
DIABETES_MVP_ALGORITHM=HS256
DIABETES_MVP_ACCESS_TOKEN_EXPIRE_MINUTES=480

# BLE Configuration
DIABETES_MVP_ACCUCHEK_SERVICE_UUID=00001808-0000-1000-8000-00805f9b34fb
DIABETES_MVP_ACCUCHEK_GLUCOSE_CHAR_UUID=00002A18-0000-1000-8000-00805f9b34fb
DIABETES_MVP_BLE_SCAN_INTERVAL=30
DIABETES_MVP_BLE_SCAN_DURATION=10

# Model Configuration
DIABETES_MVP_MODEL_PATH=./model/cnn_lstm_diabetes
DIABETES_MVP_RISK_THRESHOLD_LOW=0.4
DIABETES_MVP_RISK_THRESHOLD_HIGH=0.7
DIABETES_MVP_CLINICAL_DATA_EXPIRY_DAYS=30

# CORS
DIABETES_MVP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
